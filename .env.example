# =============================================================
# VARIABLES D'ENVIRONNEMENT — AgriPrix Backend
# Copiez ce fichier en .env et remplissez les valeurs
# =============================================================

# MongoDB
MONGODB_URI=mongodb://localhost:27017/agriprix
# En production avec Atlas:
# MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/agriprix

# JWT
JWT_SECRET=votre_secret_jwt_tres_long_et_securise_minimum_32_chars
JWT_EXPIRES_IN=7d

# Service IA Python
AI_SERVICE_URL=http://localhost:8000

# Firebase Admin SDK (pour les push notifications)
FIREBASE_PROJECT_ID=votre-projet-firebase
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@votre-projet.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Serveur
PORT=3000
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# Rate limiting
THROTTLE_TTL=60000
THROTTLE_LIMIT=100
